{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "scss:build": "sass resources/scss/main.scss resources/css/main.css",
    "scss:watch": "sass resources/scss/main.scss resources/css/main.css --watch",
    "serve": "browser-sync start --server --files \"resources/css/*.css, resources/views/**/*.html\" --startPath resources/views/publishing/index.html",
    "dev:publishing": "concurrently \"npm run scss:watch\" \"npm run serve\""
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "axios": "^1.11.0",
    "browser-sync": "^3.0.3",
    "concurrently": "^9.0.1",
    "laravel-vite-plugin": "^2.0.0",
    "sass": "^1.77.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.7"
  }
}
